    "type": "git",
    "url": "git+https://github.com/chenliuyun/switchbot-skill.git",
    "directory": "plugin/openclaw"
  },
  "bugs": "https://github.com/chenliuyun/switchbot-skill/issues",
  "main": "index.js",
  "bin": {
